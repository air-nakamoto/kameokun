{
  "name": "kameokun",
  "version": "0.0.0",
  "private": true,
  "description": "亀夫君問題WEBサービスのMVP土台（スキーマ・プロンプト・検証スクリプト・APIスケルトン）",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "validate:schema": "ajv validate -s schemas/problem.schema.json -d scripts/fixtures/valid-problem.json -c ajv-formats --spec=draft2020 --strict=false",
    "validate:cross": "node scripts/validate-problem.mjs scripts/fixtures/valid-problem.json",
    "validate": "npm run validate:schema && npm run validate:cross",
    "test:fixtures": "node scripts/test-fixtures.mjs",
    "test:session-ttl": "node scripts/test-session-ttl.mjs",
    "test": "npm run test:fixtures && npm run test:session-ttl"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ajv-cli": "^5.0.0",
    "typescript": "^5.7.0"
  }
}
